PORT=5000
NODE_ENV=development

# Project URL only — do NOT add /rest/v1
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

ADMIN_REGISTRATION_SECRET=AdminSeedSecret123!

BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@smartwaterbill.local
BREVO_SENDER_NAME=Smart Water Bill

PRICE_PER_LITER=20
LOW_BALANCE_THRESHOLD=500
MIN_STARTING_BALANCE_RWF=100

LEAK_MAX_CONTINUOUS_SECONDS=300
LEAK_ABNORMAL_FLOW_ML_PER_SEC=50

# Comma-separated allowed browser origins (CORS)
FRONTEND_URL=http://localhost:5173
# Production example:
# ALLOWED_ORIGINS=https://water-bill-gamma.vercel.app,http://localhost:5173

# Local dev on Windows if you see "unable to verify certificate" (default: enabled in development)
# SUPABASE_INSECURE_SSL=true

# Optional: npm run create-admin
# SEED_ADMIN_EMAIL=admin@smartwaterbill.local
# SEED_ADMIN_PASSWORD=Admin123!
